#!/usr/bin/env bash
# Install the 1Password polkit policy on non-NixOS systems.
#
# Background: on NixOS the `programs._1password-gui` module renders and
# installs com.1password.1Password.policy into /usr/share/polkit-1/actions/
# at switch time. On Ubuntu with home-manager standalone there is no
# equivalent — home-manager cannot write to /usr/share. Without this file
# polkit-mediated flows (system unlock, CLI biometric, SSH agent
# authorization) fail.
#
# This script replicates upstream's after-install.sh polkit step:
# render the policy template from the current 1Password Nix store path
# and install it system-wide. It is idempotent — safe to re-run after
# a 1Password upgrade.
#
# Usage: sudo bin/install-1password-polkit

set -euo pipefail

if [[ $EUID -ne 0 ]]; then
  echo "error: must run as root (use sudo)" >&2
  exit 1
fi

# Resolve the 1Password binary path. We can't rely on $PATH lookup here —
# sudo resets the environment, and `runuser -u $USER -- bash -c …` runs a
# non-login shell that never sources ~/.profile or ~/.zshrc, so
# ~/.nix-profile/bin is not on PATH. Instead, look up the invoking user's
# home dir via getent (so we don't hardcode /home/$user) and go straight
# to the well-known home-manager symlink: ~/.nix-profile/bin/1password.
INVOKER="${SUDO_USER:-$USER}"
INVOKER_HOME="$(getent passwd "$INVOKER" | cut -d: -f6)"

if [[ -z "$INVOKER_HOME" ]]; then
  echo "error: cannot resolve home directory for user $INVOKER" >&2
  exit 1
fi

ONEPW_LINK="$INVOKER_HOME/.nix-profile/bin/1password"
ONEPW_BIN="$(readlink -f "$ONEPW_LINK" 2>/dev/null || true)"

if [[ -z "$ONEPW_BIN" || ! -x "$ONEPW_BIN" ]]; then
  echo "error: 1password not found at $ONEPW_LINK" >&2
  echo "       ensure home-manager is switched and _1password-gui is in the profile" >&2
  exit 1
fi

ONEPW_SHARE="$(realpath "$(dirname "$ONEPW_BIN")/../share/1password")"
TEMPLATE="$ONEPW_SHARE/com.1password.1Password.policy.tpl"

if [[ ! -f "$TEMPLATE" ]]; then
  echo "error: policy template not found at $TEMPLATE" >&2
  exit 1
fi

# Render the list of allowed policy owners: human users (UID 1000-9999),
# capped at the first 10, matching upstream's after-install.sh exactly.
# We don't widen this — upstream's intent is that biometric/CLI auth
# requires a real human account, not a service user.
export POLICY_OWNERS
POLICY_OWNERS="$(cut -d: -f1,3 /etc/passwd \
  | grep -E ':[0-9]{4}$' \
  | cut -d: -f1 \
  | head -n 10 \
  | sed 's/^/unix-user:/' \
  | tr '\n' ' ')"

if [[ -z "${POLICY_OWNERS// /}" ]]; then
  echo "warning: no human users (UID 1000-9999) found; policy owners will be empty" >&2
fi

DEST=/usr/share/polkit-1/actions/com.1password.1Password.policy
TMP="$(mktemp)"
trap 'rm -f "$TMP"' EXIT

# Render: upstream uses `eval cat <<EOF` to expand ${POLICY_OWNERS} in the
# template. We do the same so substitution rules stay identical.
eval "cat <<EOF
$(cat "$TEMPLATE")
EOF" > "$TMP"

install -Dm0644 "$TMP" "$DEST"

echo "installed: $DEST"
echo "  source:  $TEMPLATE"
echo "  owners:  ${POLICY_OWNERS}"
echo
echo "polkitd picks up changes on next auth request; no restart needed."
